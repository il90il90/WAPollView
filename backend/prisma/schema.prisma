generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id            String   @id @default(cuid())
  jid           String   @unique
  name          String
  profilePicUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  polls         Poll[]
}

model Poll {
  id             String       @id @default(cuid())
  messageKey     String       @unique
  messageContent String?
  title          String
  description    String?
  groupId        String
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  selectableCount Int          @default(1)
  source         String       @default("whatsapp")
  isActive       Boolean      @default(true)
  isLocked       Boolean      @default(false)
  winnerOption   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  options        PollOption[]
  votes          VoteLog[]
}

model PollOption {
  id         String    @id @default(cuid())
  pollId     String
  poll       Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionText String
  optionHash String
  votes      VoteLog[]
}

model VoteLog {
  id                 String      @id @default(cuid())
  pollId             String
  poll               Poll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId           String?
  option             PollOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  voterJid           String
  voterName          String?
  voterPhone         String?
  selectedOptionText String
  source             String      @default("whatsapp")
  fingerprintId      String?
  ipAddress          String?
  isAnonymous        Boolean     @default(false)
  timestamp          DateTime    @default(now())
}

model WebVoterSession {
  id              String   @id @default(cuid())
  phone           String
  name            String
  groupJid        String
  fingerprintId   String
  fingerprintData String?
  userAgent       String?
  ipAddress       String?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())
  lastActiveAt    DateTime @default(now())

  @@index([phone])
  @@index([fingerprintId])
}

model ContactName {
  phone     String   @id
  name      String
  source    String   @default("pushName")
  updatedAt DateTime @updatedAt
}

model FraudLog {
  id                  String   @id @default(cuid())
  phone               String
  existingUser        String
  existingFingerprint String
  existingIp          String?
  attemptFingerprint  String
  attemptIp           String?
  attemptUserAgent    String?
  timestamp           DateTime @default(now())

  @@index([phone])
}

model AppSettings {
  id    String @id @default("singleton")
  key   String @unique
  value String
}
